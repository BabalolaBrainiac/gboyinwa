# supabase (required). never commit real values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# next-auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# encryption key for pii at rest: 32 bytes = 64 hex chars (e.g. openssl rand -hex 32)
ENCRYPTION_KEY=

# zeptomail (Zoho) for sending: admin invite, password reset. From: no-reply@gboyinwa.com
# use Zoho-enczapikey value as ZEPTOMAIL_API_KEY (or full "Zoho-enczapikey <key>")
ZEPTOMAIL_API_KEY=

# one-time superadmin: CREATE_SUPERADMIN_EMAIL=you@example.com npx tsx scripts/create-superadmin.ts
# optional: CREATE_SUPERADMIN_DISPLAY_NAME=Opeyemi
# password is auto-generated and printed once. run script only once; then use admin UI to add admins.

# Cloudflare R2 (document storage)
# Get these from Cloudflare R2 dashboard: https://dash.cloudflare.com/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Google Calendar API (for auto-generating Google Meet links)
# Setup instructions: https://developers.google.com/calendar/api/quickstart/nodejs
# 1. Go to https://console.cloud.google.com/
# 2. Create a project and enable Google Calendar API
# 3. Configure OAuth consent screen (External type)
# 4. Add scope: https://www.googleapis.com/auth/calendar.events
# 5. Create OAuth 2.0 credentials (Web application)
# 6. Add redirect URI: http://localhost:3000/api/auth/google/callback (dev)
#    and https://yourdomain.com/api/auth/google/callback (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
